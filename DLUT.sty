\newcommand{\maketotalcontents}{
    \begin{frame}
        \vfill
        \noindent
        \begin{minipage}[c]{0.4\textwidth}
            \centering
            {\WRYaHeiZH\fontsize{45}{50}\selectfont\textcolor{tsinghua}{目录}}\\[0.6cm]
            {\TahomaFont\fontsize{14}{16}\selectfont\textcolor{tsinghua}{\textbf{CONTENTS}}}
        \end{minipage}%
        \hfill
        \begin{minipage}[c]{0.52\textwidth}
            \fontsize{11}{14}\selectfont
            \addtolength{\baselineskip}{3.0ex}
            \tableofcontents[sectionstyle=show/show, subsectionstyle=hide]
        \end{minipage}
        \vfill
    \end{frame}
}


% 致谢页，用法：\makethankspage 或 \makethankspage[自定义文字]
\newcommand{\makethankspage}[1][谢谢观看！]{%
    \section*{}
    \begin{frame}[plain]
        \begin{tikzpicture}[remember picture, overlay]
            \node[anchor=north east, xshift=-0.2cm, yshift=-0.4cm]
                at (current page.north east) {%
                \includegraphics[height=1.4cm]{pic/logo.png}};
            \node[yshift=0.4cm] at (current page.center) {%
                \includegraphics[width=\paperwidth]{pic/background1.png}};
            \node[xshift=0.5cm, yshift=0.3cm] at (current page.center) {%
                \begin{minipage}{0.85\paperwidth}
                    \centering
                    {\usebeamerfont{title}\usebeamercolor[fg]{title}#1}
                \end{minipage}};
        \end{tikzpicture}
        \vspace{4.0cm}
        \begin{flushright}
            {\usebeamerfont{author}\textcolor{black!65}{汇报人：\insertauthor}%
            \hspace{1cm}%
            \usebeamerfont{date}\textcolor{black!65}{时间：\insertdate}\par}
        \end{flushright}
    \end{frame}%
}

% 章节页副标题，用法：在 \section 前调用 \setsectionsubtitle{文本}
\newcommand{\sectionpagesubtitle}{}
\newcommand{\setsectionsubtitle}[1]{\renewcommand{\sectionpagesubtitle}{#1}}

\AtBeginSection[]{%
    \usebackgroundtemplate{%
        \includegraphics[width=\paperwidth,height=\paperheight]{pic/seccon.png}%
    }%
    \begin{frame}[plain]
        \begin{tikzpicture}[remember picture, overlay]
            % 节编号：调节 xshift/yshift 移动位置（正=右/上，负=左/下）
            \node[anchor=center]
                at ([xshift=-0.1cm, yshift=1.2cm]current page.center) {%
                {\WRYaHeiZH\fontsize{45}{45}\selectfont\bfseries\textcolor{white}{%
                    \ifnum\value{section}<10 0\fi\arabic{section}}}%
            };
            % 节标题：xshift 控制左边缘的横向位置
            \node[anchor=west]
                at ([xshift=1.9cm, yshift=0.9cm]current page.center) {%
                \begin{minipage}{0.45\paperwidth}
                    \raggedright
                    {\WRYaHeiZH\fontsize{20}{20}\selectfont\bfseries\textcolor{white}{\insertsection}}\\[0.3cm]
                    {\WRYaHeiZH\fontsize{10}{10}\selectfont\textcolor{white}{\sectionpagesubtitle}}%
                \end{minipage}%
            };
        \end{tikzpicture}
    \end{frame}%
    \usebackgroundtemplate{}%
    \renewcommand{\sectionpagesubtitle}{}%
}

\defbeamertemplate*{title page}{customized}[1][]
{
  % 使用 TikZ 进行绝对定位
  \begin{tikzpicture}[remember picture, overlay]
  
    % 第一部分：右上角的 Logo
    % anchor=north east 表示以图片的右上角对齐页面的右上角
    % xshift 和 yshift 用于控制 Logo 距离页面边缘的留白大小
    \node[anchor=north east, xshift=-0.2cm, yshift=-0.4cm] at (current page.north east) {
        \includegraphics[height=1.4cm]{pic/logo.png} % 请根据您的 logo 比例调整高度或宽度
    };

    % 第二部分：横幅背景图 bc1.png (中间偏上 1cm)
    \node[yshift=0.4cm] at (current page.center) {
        \includegraphics[width=\paperwidth]{pic/background1.png} 
    };
    
    % 第三部分：标题和副标题文字 (右对齐)
    \node[xshift=0.5cm,yshift=0.3cm] at (current page.center) {
        \begin{minipage}{0.85\paperwidth} 
            \raggedleft % 强制右对齐
            \usebeamerfont{title}\usebeamercolor[fg]{title}\inserttitle\par
            \ifx\insertsubtitle\@empty\else
                \vskip0.8em
                \usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle\par
            \fi
        \end{minipage}
    };
  \end{tikzpicture}
  
  % --- 下半部分：机构、汇报人及时间 ---
  \vspace{4.0cm} % 向下推移，避开上方的 TikZ 悬浮层
  
  \begin{flushright}
    % 插入机构信息（如果您在主文档里定义了 \institute）
    % \ifx\insertinstitute\@empty\else
    %     \usebeamerfont{institute}\insertinstitute\par
    %     \vspace{0.4cm} % 机构与汇报人之间的垂直间距
    % \fi
    
    % 将汇报人和日期放在同一行
    {
      \usebeamerfont{author}\textcolor{black!65}{汇报人：\insertauthor}
      \hspace{1cm} 
      \usebeamerfont{date}\textcolor{black!65}{时间：\insertdate}\par
    }
  \end{flushright}
}
